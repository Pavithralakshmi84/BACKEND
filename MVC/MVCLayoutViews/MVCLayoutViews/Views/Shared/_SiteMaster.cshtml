@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title – NIT</title>
    <!-- Bootstrap 5 CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body class="bg-light">
    <div class="wrapper d-flex flex-column min-vh-100">

        <!-- Header: Logo + Banner + Mobile Toggle -->
        <header class="bg-aquamarine py-3">
            <div class="container">
                <div class="row align-items-center g-3">
                    <div class="col-auto">
                        <img src="~/Images/logo.png" alt="NIT Logo" class="rounded-circle" style="height:100px; width:100px;" />
                    </div>
                    <div class="col">
                        <img src="~/Images/header1.jpg" alt="Header Banner" class="rounded img-fluid" style="height:100px;" />
                    </div>
                    <!-- Mobile Menu Toggle Button -->
                    <div class="col-auto d-md-none">
                        <button class="navbar-toggler border-0 p-2" type="button" onclick="toggleSidebar()">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content: Sidebar + Body -->
        <div class="container-fluid flex-grow-1">
            <div class="row">
                <!-- Fixed Sidebar (Desktop) / Offcanvas (Mobile) -->
                <nav id="sidebar" class="col-md-3 col-lg-2 d-md-block bg-burlywood border-end"
                     style="position: fixed; left: 0; top: 120px; height: calc(100vh - 120px); width: 280px; z-index: 1050;">
                    <div class="navbar navbar-dark bg-primary p-4 h-100">
                        <ul class="nav flex-column flex-grow-1 mb-0">
                            <li class="nav-item fs-5 mb-4">
                                @Html.ActionLink("🏠 Home Page", "Home", "CdsIt", new { @class = "nav-link text-white fw-bold" })
                            </li>
                            <li class="nav-item fs-5 mb-4">
                                @Html.ActionLink("📝 Registration Page", "Register", "CdsIt", new { @class = "nav-link text-white fw-bold" })
                            </li>
                            <li class="nav-item fs-5 mb-4">
                                @Html.ActionLink("🔐 Login Page", "Login", "CdsIt", new { @class = "nav-link text-white fw-bold" })
                            </li>
                            <li class="nav-item fs-5 mb-4">
                                @Html.ActionLink("📚 Courses Offered", "Courses", "CdsIt", new { @class = "nav-link text-white fw-bold" })
                            </li>
                            <li class="nav-item fs-5">
                                @Html.ActionLink("ℹ️ About Us", "About", "CdsIt", new { @class = "nav-link text-white fw-bold" })
                            </li>
                        </ul>
                    </div>
                </nav>

                <!-- Main Content Area (Offset for sidebar) -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4" style="margin-left: 280px;">
                    <div class="pt-3">
                        @RenderBody()
                    </div>
                </main>
            </div>
        </div>

        <!-- Section S1 (Full Width Footer-like) -->
        <section class="bg-coral py-4 mt-auto">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-12 text-center">
                        @RenderSection("S1", false)
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer Image -->
        <footer class="bg-light border-top">
            <div class="container py-3">
                <div class="row justify-content-center">
                    <div class="col-12 text-center">
                        <img src="~/Images/footer.jpg" alt="Footer" class="img-fluid rounded shadow-sm" style="height:60px;" />
                    </div>
                </div>
            </div>
        </footer>

    </div>

    <style>
        /* Custom Background Colors */
        .bg-aquamarine {
            background-color: aquamarine !important;
        }

        .bg-burlywood {
            background-color: burlywood !important;
        }

        .bg-coral {
            background-color: coral !important;
        }

        /* Sidebar Mobile Behavior */
        @@media (max-width: 768px) {
            #sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s ease-in-out;
            }

                #sidebar.show {
                    transform: translateX(0);
                }

            main {
                margin-left: 0 !important;
            }
        }

        /* Desktop Sidebar */
        @@media (min-width: 769px) {
            main {
                margin-left: 280px;
            }
        }

        /* Overlay for mobile sidebar */
        #sidebar.show ~ main::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0,0,0,0.5);
            z-index: 1040;
        }
    </style>


    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('show');

            // Close sidebar when clicking outside (mobile)
            document.addEventListener('click', function closeSidebar(event) {
                const isClickInsideSidebar = sidebar.contains(event.target);
                const isToggleButton = event.target.closest('.navbar-toggler');

                if (!isClickInsideSidebar && !isToggleButton && sidebar.classList.contains('show')) {
                    sidebar.classList.remove('show');
                }
            }, { once: true });
        }
    </script>
</body>
</html>
